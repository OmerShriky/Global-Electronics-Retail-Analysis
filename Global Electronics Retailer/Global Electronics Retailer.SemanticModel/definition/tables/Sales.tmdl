		sourceColumn: Line Item

		annotation SummarizationSetBy = Automatic

	column 'Order Date'
		dataType: dateTime
		formatString: Short Date
		lineageTag: b70e4816-652b-489f-81c1-1ab0bbbc9fbb
		summarizeBy: none
		sourceColumn: Order Date

		variation Variation
			isDefault
			relationship: 36e1edcd-b3af-4019-bbca-d60223037296
			defaultHierarchy: LocalDateTable_d7eabbf8-5af9-47ae-8a91-26bf205ee236.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Delivery Date'
