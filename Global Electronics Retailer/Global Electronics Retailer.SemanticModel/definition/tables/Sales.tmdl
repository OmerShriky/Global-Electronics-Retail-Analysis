table Sales
	lineageTag: 28f0c59d-e3f9-4397-a972-578a8c748121

	measure Profit =
			
			SUMX(Sales,
			    VAR UnitProfit = RELATED(Products[Unit Price USD]) - RELATED(Products[Unit Cost USD])
			    VAR ExchangeRate = RELATED(Exchange_Rates[Exchange])
			    RETURN
			    Sales[Quantity] * UnitProfit * ExchangeRate
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 7a04bdfd-6bec-4574-bca1-88352919500e

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Online Store Profit' = CALCULATE([Profit],Sales[StoreKey]="0")
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 62b0e549-87ab-40bc-a656-4e6a1c37c1f6

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Sales Count' = COUNT(Sales[Order Number])
		formatString: 0
		lineageTag: dee915d2-24bc-4041-be71-7b1d234810aa

	measure 'Online Sales Count' = CALCULATE(Sales[Sales Count],Sales[StoreKey]="0")
		formatString: 0.00
		lineageTag: 1a09d628-bd8f-41dc-92de-da90fdbfe4a1

	measure 'Returning Customers' = COUNTROWS(FILTER(VALUES('Sales'[CustomerKey]),CALCULATE(COUNT('Sales'[Order Number])) > 1))
		formatString: 0
		lineageTag: 1a405685-8c7e-4f77-985d-75bd94a69564

	column 'Order Number'
		dataType: string
		lineageTag: cd7e60dc-f719-4ec7-b8da-3ad7169a1d84
		summarizeBy: none
		sourceColumn: Order Number

		annotation SummarizationSetBy = Automatic

	column 'Line Item'
