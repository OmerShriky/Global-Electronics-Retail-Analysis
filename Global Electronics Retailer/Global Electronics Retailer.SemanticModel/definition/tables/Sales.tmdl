		summarizeBy: none
		sourceColumn: Currency Code

		annotation SummarizationSetBy = Automatic

	column 'Date Exchange' = Sales[Currency Code] &"-"& Sales[Order Date].[Date]
		lineageTag: 6701a382-00e0-4640-b62d-34005d05a481
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Online = if(Sales[StoreKey]="0","Online","Offline")
		lineageTag: 2c678d83-80e7-45b4-9b0a-090ec81c235c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Location = IF(Sales[StoreKey]="0",RELATED(Customers[State]),RELATED(Stores[State]))
		lineageTag: 34444966-3e0a-4370-accd-6188c94f0311
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Location city' = IF(Sales[StoreKey]="0",RELATED(Customers[City]),RELATED(Stores[State]))
		lineageTag: 62c9cff9-40d8-4e30-a8f2-59909e42dc18
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Sales = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents("D:\Data Projects\Kaggle analysis\Global_Electronics_Retailer\Sales.csv"),[Delimiter=",", Columns=9, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
