		summarizeBy: none
		sourceColumn: Delivery Date

		variation Variation
			isDefault
			relationship: 0c9c626d-74ed-423b-aea1-89787810d888
			defaultHierarchy: LocalDateTable_befbf127-f836-40e0-b9c4-6eb703f9e049.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column CustomerKey
		dataType: string
		lineageTag: dbc4822f-ee00-4abd-a15d-eb50ac1ebe10
		summarizeBy: none
